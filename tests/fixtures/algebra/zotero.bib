	location = {Mumbai India},
	title = {Iris: Monoids and Invariants as an Orthogonal Basis for Concurrent Reasoning},
	isbn = {978-1-4503-3300-9},
	url = {https://dl.acm.org/doi/10.1145/2676726.2676980},
